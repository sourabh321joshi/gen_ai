# Server: Gemini API key (required for chat). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: server port (default 3001)
# PORT=3001

# Frontend: only set if your API is on a different origin (e.g. production backend URL)
# VITE_API_URL=https://your-api.example.com
